# --- Docker ---
DOCKER_USERNAME=yourusername

# --- Security ---
SECRET_KEY=change-me

# --- Database (MySQL) ---
MYSQL_DATABASE=marketsafe
MYSQL_USER=marketsafe
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_password

DB_HOST=db
DB_PORT=3306
DB_NAME=marketsafe
DB_USER=marketsafe
DB_PASSWORD=change_me

DB_MODE=dev

# --- Backend ---
APP_ENV=dev
API_PORT=8000

# --- Frontend ---
FRONTEND_PORT=4200
FRONTEND_URL=http://localhost:4200

# --- CORS ---
# Comma-separated list of allowed origins. Defaults to FRONTEND_URL if not set.
# For multiple origins: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- API proxy (used by frontend container) ---
API_BASE_URL=http://localhost:8000

#---minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=listing-images
